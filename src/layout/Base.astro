---
import '../design-system/index.css';
import '../layout/styles.css';
import '../features/shared/utils/dateConfig';
import SeoHead from './components/SeoHead.astro';

import { getLangFromAstro } from '../i18n';
import { getSession } from 'auth-astro/server';
const lang = getLangFromAstro(Astro.cookies);

// Detect post-registration: fire Lead pixel once when user lands after registering.
// The cookie is set by /api/auth/keycloak-register and survives through Keycloak's callback.
// Cookie value = role ('student' | 'teacher'), used as content_category in the pixel event.
const regPendingCookie = Astro.cookies.get('anyclazz_reg_pending');
const leadRole = regPendingCookie?.value || '';
const fireLeadEvent = !!leadRole;
let leadUserId = '';
if (fireLeadEvent) {
    Astro.cookies.delete('anyclazz_reg_pending', { path: '/' });
    try {
        const session = await getSession(Astro.request);
        // platformId is the Keycloak sub — matches the userId the BE uses in the CAPI event_id
        leadUserId = (session as any)?.platformId || session?.user?.id || '';
    } catch {
        // session unavailable — Lead fires without eventID deduplication
    }
}
const leadEventName = leadRole === 'student' ? 'Lead-Student' : 'Lead-Teacher';

const { title, description, keywords = [], isDark, noindex = false } = Astro.props;
---

<!doctype html>
<html lang={lang}>
    <head>
        <SeoHead
            title={title}
            description={description}
            keywords={keywords}
            noindex={noindex}
            lang={lang}
        />
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
        <!-- Meta Pixel Code -->
        <script is:inline>
            !function(f,b,e,v,n,t,s)
            {if(f.fbq)return;n=f.fbq=function(){n.callMethod?
            n.callMethod.apply(n,arguments):n.queue.push(arguments)};
            if(!f._fbq)f._fbq=n;n.push=n;n.loaded=!0;n.version='2.0';
            n.queue=[];t=b.createElement(e);t.async=!0;
            t.src=v;s=b.getElementsByTagName(e)[0];
            s.parentNode.insertBefore(t,s)}(window, document,'script',
            'https://connect.facebook.net/en_US/fbevents.js');
            fbq('init', '1260620476234864');
            fbq('track', 'PageView');
        </script>
        <noscript><img height="1" width="1" style="display:none"
            src="https://www.facebook.com/tr?id=1260620476234864&ev=PageView&noscript=1"
        /></noscript>
        <!-- End Meta Pixel Code -->
        {fireLeadEvent && (
            <script is:inline set:html={`fbq('trackCustom','${leadEventName}',{content_category:'${leadRole}'},{eventID:'lead_${leadUserId}'});`} />
        )}
    </head>
    <body class="overflow-hidden">
        <div id="portal-root"></div>
        <slot/>
    </body>
</html>