---
import Landing from '@/layout/Landing.astro';
import { getSession } from 'auth-astro/server';
import { Hero } from '@/features/landing/hero/Hero';
import { SectionWorks } from '@/features/landing/section-works/SectionWorks';
import { SectionExplore } from '@/features/landing/section-explore/SectionExplore';
import { SectionTestimonials } from '@/features/landing/section-testimonials/SectionTestimonials';
import { SectionReady } from '@/features/landing/section-ready/SectionReady';
import { Footer } from '@/features/landing/footer/Footer';
import { getImage } from 'astro:assets';

// Import images for optimization
import heroImageWebP from '@/assets/images/landing/hero.webp';
import worksImage1WebP from '@/assets/images/landing/anyclazz-works-1.webp';
import worksImage2WebP from '@/assets/images/landing/anyclazz-works-2.webp';
import worksImage3WebP from '@/assets/images/landing/anyclazz-works-3.webp';

const session = await getSession(Astro.request);

// Optimize images using Astro's built-in image optimization
const heroImage = await getImage({ 
  src: heroImageWebP, 
  format: 'webp', 
  quality: 85,
  width: 1920
});

const worksImage1 = await getImage({ 
  src: worksImage1WebP, 
  format: 'webp', 
  quality: 85,
  width: 1440
});

const worksImage2 = await getImage({ 
  src: worksImage2WebP, 
  format: 'webp', 
  quality: 85,
  width: 1440
});

const worksImage3 = await getImage({ 
  src: worksImage3WebP, 
  format: 'webp', 
  quality: 85,
  width: 1440
});
---

<Landing>
  <div class="relative bg-[var(--color-primary-100)] pt-[176px] overflow-hidden">
    {/* Dot pattern background for Hero */}
    <div 
      class="absolute inset-0 opacity-30"
      style={{
          backgroundImage: `radial-gradient(circle, var(--color-primary-700) 2px, transparent 2px)`,
          backgroundSize: '28px 28px',
          maskImage: 'radial-gradient(ellipse 70% 70% at top center, rgba(0,0,0,1) 0%, rgba(0,0,0,0.5) 30%, rgba(0,0,0,0) 50%)',
          WebkitMaskImage: 'radial-gradient(ellipse 70% 70% at top center, rgba(0,0,0,1) 0%, rgba(0,0,0,0.5) 30%, rgba(0,0,0,0) 50%)'
      }}
    />
    <div class="relative">
      <Hero heroImageUrl={heroImage.src} />
    </div>
  </div>
  <SectionWorks 
    client:visible 
    worksImage1Url={worksImage1.src}
    worksImage2Url={worksImage2.src}
    worksImage3Url={worksImage3.src}
  />
  <div class="bg-[var(--color-primary-100)]">
      <SectionExplore />
  </div>
  <SectionTestimonials client:visible />
  <div class="bg-[var(--color-primary-700)]">
      <SectionReady />
  </div>
  <div class="bg-[#F9F9F9]">
      <Footer />
  </div>
</Landing>