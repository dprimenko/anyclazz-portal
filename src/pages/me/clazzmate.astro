---
export const prerender = false;
import Main from '../../layout/Main.astro';
import { getImage } from 'astro:assets';
import { getSession } from 'auth-astro/server';
import { getLangFromAstro } from '@/i18n';
import { ReferralRepository } from '@/features/shared/infrastructure/ReferralRepository';
import { ClazzmateContent } from '@/features/shared/components/clazzmate-page/ClazzmateContent';
import type { ReferralData } from '@/features/shared/domain/referralTypes';

const session = await getSession(Astro.request);
const accessToken = session?.accessToken as string;

if (!accessToken) {
	return Astro.redirect('/login');
}

const lang = getLangFromAstro(Astro.cookies);

const referralRepository = new ReferralRepository();

let referralData: ReferralData = {
	referral_code: '',
	invite_link: '',
	friends_invited: 0,
	first_booking_conversions: 0,
	available_credits: 0,
};

try {
	referralData = await referralRepository.getReferralData({ token: accessToken });
} catch (error) {
	console.error('Error loading referral data:', error);
}

const inviteUrl = referralData.referral_code
	? `${Astro.url.origin}/ref/${referralData.referral_code}`
	: '';

const optimizedImage = await getImage({ src: "https://anyclazz.b-cdn.net/b8ff5b6aea0a3dd88236864b85f225e0dbfa5077%20(1).jpg", width: 320, height: 240 });
---

<Main title="Clazzmate">
	<ClazzmateContent
		referralData={referralData}
		inviteUrl={inviteUrl}
		imageUrl={optimizedImage.src}
		lang={lang}
		client:load
	/>
</Main>
