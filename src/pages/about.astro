---
import Landing from '@/layout/Landing.astro';
---

<Landing
    title="About Us"
    description="Anyclazz was built around a simple belief: there are people with something real to teach, and people who genuinely want to learn."
    keywords={['about anyclazz', 'about us', 'mission', 'learn', 'teach']}
>
    <div class="container mx-auto px-4 py-32 max-w-3xl">
        <h1 class="text-4xl font-bold mb-8 text-[var(--color-neutral-900)]">About Us</h1>

        <p class="text-lg text-[var(--color-neutral-700)] leading-relaxed">
            Anyclazz was built around a simple belief: there are people with something real to teach, and
            people who genuinely want to learn — and the only thing standing between them is friction.
            We're here to remove it. A space where knowledge flows naturally, between neighbors or across
            the country, between anyone with something to offer and anyone ready to grow.
        </p>
    </div>
</Landing>
