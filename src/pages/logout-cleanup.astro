---
// Esta página limpia las cookies del lado del cliente
const nextUrl = Astro.url.searchParams.get('next') || '/login';
---

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cerrando sesión...</title>
</head>
<body>
    <div style="display: flex; justify-content: center; align-items: center; height: 100dvh; font-family: system-ui;">
        <p>Cerrando sesión...</p>
    </div>
    
    <script>
        // authjs.session-token es httpOnly — JS no puede borrarlo con document.cookie.
        // Llamamos al signOut de auth.js para que él mismo limpie su cookie correctamente.
        const { signOut } = await import('auth-astro/client');

        // Limpiar localStorage
        try {
            localStorage.removeItem('anyclazz_user_profile');
            localStorage.removeItem('anyclazz_user_profile_expiry');
        } catch (_) {}

        const nextUrl = new URLSearchParams(window.location.search).get('next') || '/';

        // signOut llama a POST /api/auth/signout con el CSRF token y borra la sesión.
        // redirect: false para controlar nosotros la redirección final.
        await signOut({ redirect: false });

        window.location.href = nextUrl;
    </script>
</body>
</html>
