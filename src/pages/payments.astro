---
import { useTranslationsSSR } from "@/i18n/index.ts";
import Main from "@/layout/Main.astro";
import { getSession } from 'auth-astro/server';
import { AnyclazzAuthRepository } from "@/features/auth/ssr/infrastructure/AnyclazzAuthRepository";
import { ApiTeacherRepository } from "@/features/teachers/infrastructure/ApiTeacherRepository";
import { StripeConnectSection, StripeDashboardButtonContainer, StripeStatusBadge, StripeTestModeBadge, PaginatedPayments, PaymentsHistoryRepository, PaymentsDashboardSummary } from "@/features/stripe-connect";
import type { GetPaymentHistoryResponse, PaymentsDashboardResponse } from "@/features/stripe-connect";
import { Text } from "@/ui-library/components/ssr/text/Text.tsx";
import { Divider } from "@/ui-library/components/ssr/divider/Divider.tsx";
import { Breadcrumb } from "@/ui-library/components/breadcrumb";
import { Space } from "@/ui-library/components/ssr/space/Space";

export const prerender = false;

const session = await getSession(Astro.request);
const accessToken = session?.accessToken as string;

if (!accessToken) {
    return Astro.redirect('/login');
}

const authRepository = new AnyclazzAuthRepository();
const user = await authRepository.getCurrentUser(session);
const lang = (user?.language ?? 'en') as 'en' | 'es';
const t = useTranslationsSSR({ token: session?.accessToken });

if (!user?.id) {
    return Astro.redirect('/login');
}

// Solo teachers pueden acceder a esta página
if (user.role !== 'teacher') {
    return Astro.redirect('/dashboard');
}

const teacherRepository = new ApiTeacherRepository();
const teacher = await teacherRepository.getTeacher({ 
    token: accessToken,
    teacherId: user.id
});

// Cargar el estado de Stripe Connect en el servidor
let stripeConnectStatus = null;
try {
    stripeConnectStatus = await teacherRepository.getStripeConnectStatus({ 
        token: accessToken 
    });
} catch (error) {
    console.error('Error loading Stripe Connect status:', error);
}

// Cargar el historial de pagos en el servidor
const paymentsHistoryRepository = new PaymentsHistoryRepository();
let initialPayments: GetPaymentHistoryResponse = { payments: [], meta: { currentPage: 1, lastPage: 1, size: 10, total: 0 } };
try {
    initialPayments = await paymentsHistoryRepository.getPaymentHistory({ token: accessToken, page: 1, limit: 10 });
} catch (error) {
    console.error('Error loading payment history:', error);
}

let paymentsDashboard: PaymentsDashboardResponse | null = null;
try {
    paymentsDashboard = await paymentsHistoryRepository.getPaymentsDashboard({ token: accessToken });
} catch (error) {
    console.error('Error loading payments dashboard:', error);
}

const requirementsDue = stripeConnectStatus?.requirements?.currently_due?.length || 0;

// Extraer parámetros OAuth de la URL
const oauthCode = Astro.url.searchParams.get('code');
const oauthState = Astro.url.searchParams.get('state');
const oauthError = Astro.url.searchParams.get('error');
const oauthErrorDescription = Astro.url.searchParams.get('error_description');
---

<Main title="Payments">
	<div class="px-4 py-2 sm:p-8">
		<Breadcrumb
			items={[
				{ label: t('menu.payments'), href: '/payments' },
			]}
		/>
		<Space size={16} direction="vertical" />
        
		<!-- Indicador de Modo Test -->
		<!-- <StripeTestModeBadge lang={lang} client:load /> -->
		
        <div class="flex flex-col gap-2 md:flex-row md:items-center justify-between">
            <div class="flex flex-col">
                <div class="flex flex-row items-center gap-3">
                    <Text colorType='primary' weight='semibold' size="text-2xl">{t('menu.dashboard.payments')}</Text>
                    {stripeConnectStatus && (
                        <StripeStatusBadge 
                            status={stripeConnectStatus.status}
                            canReceivePayments={stripeConnectStatus.can_receive_payments}
                            requirementsDue={requirementsDue}
                            lang={lang}
                            client:load
                        />
                    )}
                </div>
                <Text size="text-md" colorType="tertiary">
                {stripeConnectStatus?.status === 'enabled' ? t('menu.dashboard.payments_description') : t('stripe.description')}
                </Text>
            </div>
            {stripeConnectStatus?.connected && stripeConnectStatus?.can_receive_payments && (
                <div class="flex flex-col">
                    <StripeDashboardButtonContainer 
                        accessToken={accessToken}
                        client:load
                    />
                </div>
            )}
        </div>
        
		<Space size={16} direction="vertical" />
		<Divider />
		<Space size={32} direction="vertical" />

		<!-- Stripe Connect Section -->
        <StripeConnectSection 
            accessToken={accessToken}
            country={teacher.teacherAddress?.country || 'US'}
            initialStatus={stripeConnectStatus}
            oauthCode={oauthCode}
            oauthState={oauthState}
            oauthError={oauthErrorDescription || oauthError}
            lang={lang}
            client:load
        />

        {!stripeConnectStatus?.connected && !stripeConnectStatus?.can_receive_payments && (
            <Space size={48} direction="vertical" />
        )}

		<!-- Historial de pagos -->
		{paymentsDashboard && (
			<>
				<PaymentsDashboardSummary dashboard={paymentsDashboard} lang={lang} client:load />
				<Space size={32} direction="vertical" />
			</>
		)}
        
		<PaginatedPayments
			initialPayments={initialPayments}
			accessToken={accessToken}
			lang={lang}
			client:load
		/>
	</div>

	<!-- Script para limpiar URL después de procesar OAuth -->
	<script>
		// Limpiar parámetros OAuth de la URL sin recargar la página
		const urlParams = new URLSearchParams(window.location.search);
		if (urlParams.has('code') || urlParams.has('error')) {
			const cleanUrl = window.location.pathname;
			window.history.replaceState({}, '', cleanUrl);
		}
	</script>
</Main>

