---
export const prerender = false;
import Base from '../layout/Base.astro';
import { getSession } from 'auth-astro/server';
import {routeConfig} from '../config/routes.ts';

// Verificar si el usuario acaba de hacer logout
const loggedOutCookie = Astro.cookies.get('user_logged_out');
const isLoggingOut = loggedOutCookie?.value === 'true';

// Si está en proceso de logout, eliminar la cookie para futuras solicitudes
if (isLoggingOut) {
  Astro.cookies.delete('user_logged_out', { path: '/' });
  console.log('🗑️ Cleared user_logged_out cookie in login page');
}

const session = await getSession(Astro.request);

// Solo redirigir si hay sesión Y NO está en proceso de logout
if (session?.user && !isLoggingOut) {
  // Si hay sesión, redirigir (el middleware ya maneja el callbackUrl)
  return Astro.redirect(routeConfig.defaultRedirectRoute);
}

// Pasar el callbackUrl al cliente
const url = new URL(Astro.request.url);
const callbackUrl = url.searchParams.get('callbackUrl');
---

<Base noindex={true}>
	<div class="login-container">
		<div class="loader"></div>
	</div>

	<style>
		.login-container {
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			height: 100dvh;
			gap: 20px;
		}

		.loader {
			border: 4px solid var(--neutral-200);
			border-top: 4px solid var(--primary-500);
			border-radius: 50%;
			width: 40px;
			height: 40px;
			animation: spin 1s linear infinite;
		}

		@keyframes spin {
			0% { transform: rotate(0deg); }
			100% { transform: rotate(360deg); }
		}
	</style>

	<script>
		const { signIn } = await import("auth-astro/client");

		async function redirectToKeycloak() {
			try {
				const urlParams = new URLSearchParams(window.location.search);
				const callbackUrl = urlParams.get('callbackUrl');
				if (callbackUrl) {
					sessionStorage.setItem('auth_callback_url', callbackUrl);
				}

				await signIn("keycloak");
			} catch (error) {
				console.error('Error durante el sign in:', error);
			}
		}

		// Auto-redirigir a Keycloak igual que antes.
		// El usuario puede marcar "Recordarme" antes de que ocurra la redirección.
		setTimeout(redirectToKeycloak, 100);
	</script>
</Base>
