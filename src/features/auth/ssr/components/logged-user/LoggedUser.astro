---
import './styles.css'
import { AnyclazzAuthRepository } from "../../infrastructure/AnyclazzAuthRepository"
import { getSession } from 'auth-astro/server';
import { LoggedUserClient } from './LoggedUserClient';

const session = await getSession(Astro.request);
const loggedUser = new AnyclazzAuthRepository();
const user = await loggedUser.getCurrentUser(session);
const accessToken = (session as any)?.accessToken as string | undefined;
const lang = (Astro.cookies.get('app_lang')?.value || 'en') as 'en' | 'es';
---

{user && (
    <LoggedUserClient 
        lang={lang}
        user={user}
        accessToken={accessToken}
        client:load
    />
)}